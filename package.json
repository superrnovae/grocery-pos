{
  "name": "grocery-pos",
  "version": "1.0.0",
  "description": "Point-of-sale desktop application for a neighborhood grocery store (Electron course final project)",
  "main": "./out/main/index.js",
  "author": "Grocery POS Team",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild:electron": "electron-rebuild --force --module-dir . --which-module better-sqlite3",
    "predev": "npm run rebuild:electron",
    "dev": "electron-vite dev",
    "prestart": "npm run rebuild:electron",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "npm run rebuild:electron",
    "prebuild:unpack": "npm run rebuild:electron",
    "build:unpack": "npm run build && electron-builder --dir",
    "prebuild:win": "npm run rebuild:electron",
    "build:win": "npm run build && electron-builder --win",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "posttest": "npm run rebuild:electron"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.11.1",
    "pinia": "^3.0.4",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.9",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  }
}
